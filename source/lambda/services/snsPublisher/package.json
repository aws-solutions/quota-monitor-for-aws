{
  "name": "quota-monitor-sns-publisher",
  "description": "microservice for filtering and publishing warnings and errors to sns",
  "main": "./index.js",
  "author": {
    "name": "Amazon Web Services",
    "url": "https://aws.amazon.com/solutions"
  },
  "license": "Apache-2.0",
  "version": "6.3.7",
  "private": "true",
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.962.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "pretest": "npm ci",
    "test": "npx jest",
    "build:clean": "rm -rf ./node_modules && rm -rf ./dist",
    "build:ts": "npx tsc --project ./tsconfig.json",
    "postinstall": "npm run build:ts",
    "build:copy": "cp -r ./node_modules ./dist/services/snsPublisher",
    "build:zip": "cd ./dist/services/snsPublisher && zip -rq sns-publisher.zip . && mv sns-publisher.zip ../../",
    "build:all": "npm run build:clean && npm ci && npm prune --production && npm run build:copy && npm run build:zip",
    "coverage": "nyc npm test"
  },
  "bundledDependencies": []
}
